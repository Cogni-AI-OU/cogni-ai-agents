%% AGENTS.mmd: Canonical Booting Sequence & Initialization Protocols
%% This file is the primary entry point for agent activation.

    subgraph Core_Initialization_Sequence [Initialization Sequence]
        direction TB
        %% Note: FL6, IL6, CL6, and SL8 are the contractual terminal nodes relied on by this sequence
        IS_FL["Execute Mandatory_Facts_Loading_Protocol (docs/FACTS.mmd)"] --> FL1
        FL6 --> IS1["Agent Contract Alignment (AGENTS.mmd, docs/FLOWS.mmd)"]
        IS1 --> IS_CL["Execute Mandatory_Constraints_Loading_Protocol (CONSTRAINTS.mzn)"]
        IS_CL --> CL1
        CL6 --> IS_AL["Agent Contract Alignment (Root AGENTS.md + Local AGENTS.md)"]
        IS_AL --> IS2["Load [.github/copilot-instructions.md](.github/copilot-instructions.md)"]
        IS2 --> IS_IL["Execute Mandatory_Instructions_Loading_Protocol"]
        IS_IL --> IL1
        IL6 --> IS_SL["Execute Mandatory_Skill_Loading_Protocol"]
        IS_SL --> SL1
        SL8 --> IS5

        IS5["Context Intake (Read project memory, trackers, and docs guided by loaded instructions)"] --> IS6

        IS6["Pre-Flight Snapshot (Synthesize into single entropy-minimized sentence)"] --> IS7

        IS7["Strategy Initialization (Design-It-Twice & sequence-linked #todos)"] --> IS8

        IS8["Task Refinement (Decompose into atomic sub-tasks, no artificial grouping)"] --> IS9

        IS9["Autonomous Engagement (Immediately transition to Workflow Contract execution)"] --> FLOWS["Refer to docs/FLOWS.mmd for operational protocols"]
    end

    subgraph Mandatory_Constraints_Loading_Protocol
        CL1[Locate CONSTRAINTS.mzn in Repo] --> CL2{CONSTRAINTS.mzn Exists?}
        CL2 -->|Yes| CL3[Parse Project Constraints & Invariants]
        CL3 --> CL4[Inject Core Logic Context into Working Memory]
        CL2 -->|No| CL5[Proceed Without Constraint Bounds]
        CL4 --> CL6[Align Execution Bounds with Restrictions]
        CL5 --> CL6
    end

    subgraph Mandatory_Facts_Loading_Protocol
        FL1[Locate docs/FACTS.mmd in Repo] --> FL2{docs/FACTS.mmd Exists?}
        FL2 -->|Yes| FL3[Parse Project Facts & Invariants]
        FL3 --> FL4[Inject Core Context into Working Memory]
        FL2 -->|No| FL5[Proceed Without Canonical Facts]
        FL4 --> FL6[Align Strategy with Project Facts]
        FL5 --> FL6
    end

    subgraph Mandatory_Instructions_Loading_Protocol
        IL1[Scan Context for .instructions.md] --> IL2{Instructions Found?}
        IL2 -->|Yes| IL3[Match Context to Instruction Scope]
        IL3 --> IL4[Read Relevant .instructions.md Files]
        IL2 -->|No| IL5[Proceed Without Domain Instructions]
        IL4 --> IL6[Apply Instruction Rules to Execution]
        IL5 --> IL6
    end

    subgraph Mandatory_Skill_Loading_Protocol
        SL1[Check .github/skills/AGENTS.md] --> SL2{Skills Found?}
        SL2 -->|Yes| SL3[Route Intent: Match Skill Name/Alias/Keyword]
        SL2 -->|No| SL6[Proceed Without Skill]
        SL3 --> SL4{Multiple Matches?}
        SL4 -->|Yes| SL5[Load Non-Overlapping or Most Specific]
        SL4 -->|No| SL5
        SL5 --> SL7[Read Best-Matching SKILL.md Files]
        SL7 --> SL8[Proceed with Execution]
        SL6 --> SL8
    end
