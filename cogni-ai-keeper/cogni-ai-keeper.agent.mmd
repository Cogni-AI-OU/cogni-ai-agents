flowchart TD
    Start([Activation]) --> Boot[Initialization Sequence]

    subgraph GLOBAL_AGENTS_md [AGENTS.md: Global Contract]
        direction TB
        B1["1- Store Discovery"]
        B2["2- Schema Validation"]
        B3["3- Contradiction & Integrity Scan"]
        B4["4- Provenance Audit"]
    end

    subgraph LOCAL_CONTRACT [keeper.agent.md: Local Framework]
        B5["5- Emit Boot Report"]
        Idle{"6- Await Action"}

        Idle -->|"Command / Trigger"| Input[Parse Invocation]

        Input --> Gate{"Is Operation Authorized?"}
        Gate -->|No| Reject["Emit: UNAUTHORIZED_OPERATION"]
        Reject --> Idle

        Gate -->|Yes| Mode{Select Mode}

        Mode -->|Ingest/Add| P1[Extract Provenance & Facts]
        Mode -->|Sync/Reconcile| P2[Compare Memory vs Reality]
        Mode -->|Prune/Audit| P3[Identify Stale/Orphaned Nodes]

        P1 & P2 & P3 --> Core[Apply Logic Engine]

        Core --> Mutation{"State Change Required?"}

        Mutation -->|No| Report["Generate Status Report"]
        Mutation -->|Yes| Commit["Write to [FACTS.mmd / AGENTS.md]"]

        Commit & Report --> Finalize[Self-Consistency Pass]
        Finalize --> Output["Emit: KEEPER SUCCESS"]
    end

    subgraph GLOBAL_FLOWS_mmd [FLOWS.mmd: Shared Protocols]
        direction TB
        TL{Traffic Light Classification}

        subgraph Extrinsic_Escalation_Protocol [Extrinsic Escalation Protocol: 10-Point Gate]
            direction TB
            EE_Trig{Trigger Extrinsic Escalation}
            EE_Trig -->|Missing API/Auth| EE1[Credential Lock]
            EE_Trig -->|Structural Obj Complete| EE2[Milestone Validation]
            EE_Trig -->|Quota/Hardware/Perms| EE3[Environment Hard-Block]
            EE_Trig -->|Logical Impossibility| EE4[Requirement Contradiction]
            EE_Trig -->|Exhausted Clarification| EE5[Irresolvable Ambiguity]
            EE_Trig -->|All Avenues Failed| EE6[Vector Exhaustion]
            EE_Trig -->|Deep Architectural Fork| EE7[High-Stakes Trade-Off]
            EE_Trig -->|Force-Push/Data Mutation| EE8[Destructive Confirmation]
            EE_Trig -->|Intractable Critical Bug| EE9[Persistent Regression]
            EE_Trig -->|Restrictive Egress Block| EE10[Network/Firewall Isolation]
        end

        EE1 & EE2 & EE3 & EE4 & EE5 & EE6 & EE7 & EE8 & EE9 & EE10 --> Escalate[Extrinsic Escalation: 10-Point Gate]
    end

    Boot --> GLOBAL_AGENTS_md
    GLOBAL_AGENTS_md --> B5

    Core --> TL
    TL -->|Green: Autonomous| Mutation
    TL -->|Yellow: Collaborative| EscalateGate{Escalation Required?}
    EscalateGate -->|Yes| EE_Trig
    Escalate -->|User Input Received| Mutation
    EscalateGate -->|No| Mutation

    Output --> Idle

    subgraph Invariants ["Keeper Invariants"]
        direction TB
        I1["Canonical Truth Only"]
        I2["Atomic Integrity"]
        I3["Zero Ambiguity"]
        I4["Entropy Resistance"]
        I5["Non-Destructive SCM First"]
        I6["Provenance-Linked Facts"]
    end

    Input -.governed by.-> I3
    Commit -.governed by.-> I1
    Commit -.governed by.-> I2
    P1 -.governed by.-> I6
    P3 -.governed by.-> I4
    Output -.governed by.-> I5

    classDef phaseNode fill:#1e3a5f,stroke:#4a90e2,stroke-width:2px,color:#fff
    classDef gateNode fill:#5f1e1e,stroke:#e24a4a,stroke-width:2px,color:#fff
    classDef checkNode fill:#5f4a1e,stroke:#e2a04a,stroke-width:2px,color:#fff
    classDef endNode fill:#1e5f3a,stroke:#4ae290,stroke-width:2px,color:#fff
    classDef guardNode fill:#3a2a4a,stroke:#a070c0,stroke-width:1px,color:#eee

    class Boot,Input,Core,Finalize,B1,B2,B3,B4,B5 phaseNode
    class Idle,Gate,Mode,Mutation,TL,EscalateGate gateNode
    class Reject,Commit,Report,Escalate checkNode
    class Start,Output endNode
    class I1,I2,I3,I4,I5,I6 guardNode
