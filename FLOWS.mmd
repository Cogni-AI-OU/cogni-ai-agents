flowchart TD
%% Project Execution Flows & Protocol Logic for Agents
%% Note: Keep subgraphs and unordered items in alphabetical order.

    subgraph Command_Failure_Recovery_Protocol [Command Failure Recovery Protocol - Bounded Scheduler v3]
        direction TB
        CFR1["Command Fails"] --> CFR_GUARD["Guardrail Executor<br/>(Pre: memo + growth + progress + budget + ImmutablePlanVersion check)"]

        CFR_GUARD --> CFR_TAX["Failure Taxonomy Classification<br/>(POLICY_DENIED | PATH_MUTATION_GROWTH | TRANSIENT | LOG_ACCESS | AUTH_ENV | NOT_FOUND | OTHER)"]

        CFR_TAX --> CFR_MEMO_PROG["Progress + Memo Gate<br/>(NewArtifact \/ HypothesisNarrowed \/ TerminationSignal ?)<br/>+ Sliding-Window Repetition (RepetitionWindow)"]

        CFR_MEMO_PROG -->|No Progress, Repetition >=3, OR BudgetExhausted| CFR_ARREST["Loop Arrest v3<br/>-> Hard Stop / Terminal Escalation"]
        CFR_MEMO_PROG -->|Progress OK| CFR_LAYER{"Recovery Layer? (3-Layer Escalation Protocol)"}

        CFR_LAYER -->|&quot;Layer 1: Retry Transient&quot;| CFR_BOUNDED["Bounded Retry + Backoff<br/>(per-objective budget; ImmutablePlanVersion preserved)"]
        CFR_LAYER -->|&quot;Layer 2: Local Patch&quot;| CFR_REWIND_PATH["Rewind to Last Known-Valid + Patch<br/>(repo-discovered only)"]
        CFR_LAYER -->|&quot;Layer 3: Full Escalate&quot;| CFR_ESCALATE["Immediate Escalation<br/>(Extrinsic Gate 3; closed loop - no LLM feedback)"]

        CFR_BOUNDED --> CFR_REMEDY["Execute Contextual Remedies<br/>(Verify Access -> Pivot Fallbacks -> Safe Installs)"]
        CFR_REWIND_PATH --> CFR_REMEDY
        CFR_ESCALATE --> CFR9

        CFR_REMEDY --> CFR5{"Upstream CI/CD Issue?"}

        CFR5 -->|Yes| CFR6["Halt & Escalate (Extrinsic Gate 3)"]
        CFR5 -->|No| CFR8{"Hit Iteration Limits or Blockers?"}

        CFR8 -->|Yes| CFR9["Blocker Reporting (state, impact, mitigations)"]
        CFR8 -->|No| CFR11["Retry Execution (Re-execute Command)"]
        CFR11 -->|Failure| CFR_GUARD
        CFR11 -->|Success| CFR12(["Recovery Complete<br/>+ Telemetry: repeated_hits, stagnation_events, drift_detected, budget_exhausted, loop_arrest_activations"])
    end

    subgraph Core_Initialization_Sequence [Initialization Sequence]
        direction TB
        %% Note: FL6, IL6, CL6, and SL8 are the contractual terminal nodes relied on by this sequence
        IS_FL["Execute Mandatory_Facts_Loading_Protocol (FACTS.mmd)"] --> FL1
        FL6 --> IS1["Agent Contract Alignment (AGENTS.mmd, FLOWS.mmd)"]
        IS1 --> IS_CL["Execute Mandatory_Constraints_Loading_Protocol (CONSTRAINTS.mzn)"]
        IS_CL --> CL1
        CL6 --> IS_AL["Agent Contract Alignment (Root AGENTS.md + Local AGENTS.md)"]
        IS_AL --> IS2["Load [.github/copilot-instructions.md](.github/copilot-instructions.md)"]
        IS2 --> IS_IL["Execute Mandatory_Instructions_Loading_Protocol"]
        IS_IL --> IL1
        IL6 --> IS_SL["Execute Mandatory_Skill_Loading_Protocol"]
        IS_SL --> SL1
        SL8 --> IS5

        IS5["Context Intake (Read project memory, trackers, and docs guided by loaded instructions)"] --> IS6

        IS6["Pre-Flight Snapshot (Synthesize into single entropy-minimized sentence)"] --> IS7

        IS7["Strategy Initialization (Design-It-Twice & sequence-linked #todos)"] --> IS8

        IS8["Task Refinement (Decompose into atomic sub-tasks, no artificial grouping)"] --> IS9

        IS9["Autonomous Engagement (Immediately transition to Workflow Contract execution)"]
    end

    subgraph DbC_Enforcement_Protocol [Design-by-Contract Enforcement]
        direction TB
        DbC1["Intend State Mutation"] --> DbC2
        DbC2["Emit Precondition Assertion (Pre: constraints_satisfied)"] --> DbC3
        DbC3["Perform Mutation"] --> DbC4
        DbC4["Emit Postcondition Assertion (Post: verified)"] --> DbC5
        DbC5["Perform Chain-of-Verification (Crash-early semantics)"] --> DbC6
        DbC6{"Hard Checkpoint reached?"}
        DbC6 -->|Yes| DbC7["Emit Invariant Checksum Vectors"]
        DbC7 --> DbC8{"Mismatch with prior checkpoints?"}
        DbC8 -->|Yes| DbC9["Trigger Metacognitive Rewind Protocol"]
        DbC8 -->|No| DbC10(["Continue Execution"])
        DbC6 -->|No| DbC10
    end

    subgraph Defensive_Blast_Radius_Containment_Protocol [Defensive Blast-Radius Containment Protocol]
        direction TB
        BR1["Identify wide-ranging, destructive, or high-risk modification"] --> BR2
        BR2["Perform strict impact assessment (Explicitly model the blast radius)"] --> BR3
        BR3["Define robust rollback strategy and ensure state backup"] --> BR4
        BR4{"High-risk vector?"}
        BR4 -->|Yes| BR5["Pause for explicit validation (Trigger Escalation Gate as needed)"]
        BR4 -->|No| BR6["Commit to execution"]
        BR5 -->|Validation Received| BR6
        BR6 --> BR7["Execute operation"]
        BR7 --> BR8["Verify target environments and corresponding tests"]
    end

    subgraph Design_It_Twice_Protocol [Design-It-Twice Protocol]
        direction TB
        DT1["Identify non-trivial strategy/component"] --> DT2
        DT2["Generate Design A"] --> DT3
        DT3["Generate Design B (substantially different)"] --> DT4
        DT4["Rigorously compare via explicit trade-off matrix"] --> DT5
        DT5["Select and commit to optimal path"]
    end

    subgraph Extrinsic_Escalation_Protocol [Extrinsic Escalation Protocol: 10-Point Gate]
        direction TB
        EE_Trig{Trigger Extrinsic Escalation}
        EE_Trig -->|Missing API/Auth| EE1[Credential Lock]
        EE_Trig -->|Structural Obj Complete| EE2[Milestone Validation]
        EE_Trig -->|Quota/Hardware/Perms| EE3[Environment Hard-Block]
        EE_Trig -->|Logical Impossibility| EE4[Requirement Contradiction]
        EE_Trig -->|Exhausted Clarification| EE5[Irresolvable Ambiguity]
        EE_Trig -->|All Avenues Failed| EE6[Vector Exhaustion]
        EE_Trig -->|Deep Architectural Fork| EE7[High-Stakes Trade-Off]
        EE_Trig -->|Force-Push/Data Mutation| EE8[Destructive Confirmation]
        EE_Trig -->|Intractable Critical Bug| EE9[Persistent Regression]
        EE_Trig -->|Restrictive Egress Block| EE10[Network/Firewall Isolation]
    end

    subgraph Failure_Taxonomy ["Failure Taxonomy (Gating Matrix)"]
        direction TB
        FT1["Classify Error Signature"] --> FT2{"POLICY_DENIED / ALLOWLIST / LOG_ACCESS?"}
        FT2 -->|Yes| FT3["Never retry -> Pivot/Escalate"]
        FT2 -->|No| FT4{"PATH_MUTATION + arg growth?"}
        FT4 -->|Yes| FT5["Rewind to last known-valid"]
        FT4 -->|No| FT6{"TRANSIENT only?"}
        FT6 -->|Yes| FT7["Bounded retry + backoff + budget"]
        FT6 -->|No| FT8["Escalate / Non-retryable"]
    end

    subgraph Global_Invariants ["Global Invariants (Scheduler-Theoretic)"]
        direction TB
        GI1["MaxRecoveryDepth (bounded)"] --> GI2["ImmutablePlanVersion = true"]
        GI2 --> GI3["GuardrailPreFlight = (memo /\ growth /\ progress /\ budget)"]
        GI3 --> GI4["IsRetryable[Class] -> gated retry only"]
    end


    subgraph Global_Budget_Protocol ["Global Budget Protocol (New - Research Hard Limits)"]
        direction TB
        GBP1["Per-run / Per-objective Budgets<br/>(max_steps=20, max_tool_calls=N, token_budget, time_TTL)"] --> GBP2{"Budget Exhausted?"}
        GBP2 -->|Yes| GBP3["Hard Stop + Escalate<br/>(override any internal loop)"]
        GBP2 -->|No| GBP4["Decrement & Continue"]
    end

    subgraph Guardrail_Executor ["Guardrail Executor (New - External Enforcement Wrapper)"]
        direction TB
        GE1["Every Tool Invocation Routes Here"] --> GE2["Global_Budget_Protocol Check"]
        GE2 --> GE3["Loop_Arrest_Protocol Check"]
        GE3 --> GE4["Memo + Growth + Progress Pre-flight"]
        GE4 -->|All Pass| GE5["Execute Tool"]
        GE4 -->|Any Fail| GE6["Immediate Arrest / Rewind"]
    end

    subgraph Failed_Build_Diagnosis ["Failed Build Diagnosis (Updated)"]
        FB1[Trigger: Build Failure] --> FB2[Identify Last Green Build]
        FB2 --> FB3[Compare Changes: git diff/log]
        FB3 --> FB4["Analyze Logs: gh run view --log-failed OR gh api .../logs<br/>(empty/403 treated as LOG_ACCESS_UNSUPPORTED -> NON_RETRYABLE)"]
        FB4 --> FB5{Identify Cause}
        FB5 -->|Syntax| FB6[Validate Syntax]
        FB5 -->|Regression| FB7[Trace to Recent Change]
        FB5 -->|Timeout/Temp| FB8[Retry only if TRANSIENT]
        FB6 --> FB9[Propose & Implement Fix]
        FB7 --> FB9
        FB8 --> FB9
    end

    subgraph Git_Branch_Sync_Policy
        BS1[Determine PR Base & Head] --> BS2[Check PR Head Branch]
        BS2 --> BS3["Pull Head (No Rebase)"]
        BS3 --> BS4{"Integration needed?"}
        BS4 -->|Yes| BS5["Fetch Base & Merge (No Fast-Forward)"]
        BS5 --> BS6[Resolve Conflicts & Commit]
        BS4 -->|No| BS7[Verify No Rebase Executed]
        BS6 --> BS7
        BS7 --> BS8[Push to Remote]
    end

    subgraph Loop_Arrest_Protocol ["Loop Arrest Protocol v2 (Enhanced)"]
        direction TB
        LAP1["Pre-Retry: Fingerprint + Sliding Window (last 5 steps)"] --> LAP2{"Memo Hit OR Repetition >=3?"}
        LAP2 -->|Yes| LAP3["Hard-Stop This Branch -> Escalation / Rewind"]
        LAP2 -->|No| LAP4["Progress Growth Detector + Budget Check"]
        LAP4 -->|No Growth OR Budget Exceeded| LAP5["Rewind / Halt"]
        LAP4 -->|Growth Exists / OK| LAP6["Non-Progress Counter (2 consecutive)"]
        LAP6 -->|Threshold Exceeded| LAP3
        LAP6 -->|OK| LAP7["Proceed to Progress Contract"]
    end

    subgraph Mandatory_Constraints_Loading_Protocol
        CL1[Locate CONSTRAINTS.mzn in Repo] --> CL2{CONSTRAINTS.mzn Exists?}
        CL2 -->|Yes| CL3[Parse Project Constraints & Invariants]
        CL3 --> CL4[Inject Core Logic Context into Working Memory]
        CL2 -->|No| CL5[Proceed Without Constraint Bounds]
        CL4 --> CL6[Align Execution Bounds with Restrictions]
        CL5 --> CL6
    end

    subgraph Mandatory_Facts_Loading_Protocol
        FL1[Locate FACTS.mmd in Repo] --> FL2{FACTS.mmd Exists?}
        FL2 -->|Yes| FL3[Parse Project Facts & Invariants]
        FL3 --> FL4[Inject Core Context into Working Memory]
        FL2 -->|No| FL5[Proceed Without Canonical Facts]
        FL4 --> FL6[Align Strategy with Project Facts]
        FL5 --> FL6
    end

    subgraph Mandatory_Instructions_Loading_Protocol
        IL1[Scan Context for .instructions.md] --> IL2{Instructions Found?}
        IL2 -->|Yes| IL3[Match Context to Instruction Scope]
        IL3 --> IL4[Read Relevant .instructions.md Files]
        IL2 -->|No| IL5[Proceed Without Domain Instructions]
        IL4 --> IL6[Apply Instruction Rules to Execution]
        IL5 --> IL6
    end

    subgraph Mandatory_Skill_Loading_Protocol
        SL1[Check .github/skills/AGENTS.md] --> SL2{Skills Found?}
        SL2 -->|Yes| SL3[Route Intent: Match Skill Name/Alias/Keyword]
        SL2 -->|No| SL6[Proceed Without Skill]
        SL3 --> SL4{Multiple Matches?}
        SL4 -->|Yes| SL5[Load Non-Overlapping or Most Specific]
        SL4 -->|No| SL5
        SL5 --> SL7[Read Best-Matching SKILL.md Files]
        SL7 --> SL8[Proceed with Execution]
        SL6 --> SL8
    end

    subgraph Metacognitive_Rewind_Protocol [Metacognitive Rewind Protocol]
        direction TB
        MR1["Contradiction Detected"] --> MR2
        MR2["Emit 'CONTRADICTION at step N' (No in-place patching)"] --> MR3
        MR3["Rewind to last matching Pre/Post pair"] --> MR4
        MR4["Discard all downstream derivations"] --> MR5
        MR5["Restart the proof/logic chain"] --> MR6
        MR6["Verify every step anomaly-free before claiming solution"]
    end

    subgraph Reasoning_Activation_Protocol [Reasoning Activation Protocol: Constraint Mapping]
        direction TB
        RAV1["Confront reasoning/constraint task"] --> RAV2
        RAV2(["HARD STOP"]) --> RAV3
        RAV3["Write formal constraint declaration (e.g. MiniZinc)"] --> RAV4
        RAV4["Evaluate next alternative"] --> RAV5
        RAV5{"Lacks traceable constraint?"}
        RAV5 -->|Yes| RAV6["Reject and trigger Metacognitive Rewind Protocol"]
        RAV6 --> RAV4
        RAV5 -->|No| RAV7["Execute elimination trace"]
        RAV7 --> RAV8{"More alternatives?"}
        RAV8 -->|Yes| RAV4
        RAV8 -->|No| RAV9(["Generate final solution"])
    end

    subgraph Scratchpad_Protocol [Drafting & Commitment Partitioning: Scratchpad Protocol]
        direction TB
        SP1["Idea/Candidate Generated"] --> SP2
        SP2["Place in 'Draft Memory' (Scratchpad)"] --> SP3
        SP3["Evaluate formal logical forcing functions"] --> SP4
        SP4{"Explicitly triggered? (e.g., all others eliminated)"}
        SP4 -->|Yes| SP5["Promote to 'Committed State'"]
        SP4 -->|No| SP6["Keep isolated as unverified projection"]
    end

    subgraph State_Compression_Protocol [State-Compression Protocol]
        direction TB
        CP1["Partition task into <= 8 steps"] --> CP2
        CP2["Execute single step"] --> CP3
        CP3["Emit Mini-Checkpoint"] --> CP4
        CP4["Verify Invariants"] --> CP5
        CP5{"Step count?"}
        CP5 -->|&quot;>= 5 steps&quot;| CP6["Emit Hard Checkpoint"]
        CP6 --> CP7["Clean Re-serialization"]
        CP5 -->|&quot;< 5 steps&quot;| CP8{"Contradiction detected?"}
        CP7 --> CP8
        CP8 -->|Yes| CP9["Metacognitive Rewind Protocol"]
        CP9 --> CP2
        CP8 -->|No| CP10{"More steps?"}
        CP10 -->|Yes| CP2
        CP10 -->|No| CP11(["Batch Complete"])
    end
